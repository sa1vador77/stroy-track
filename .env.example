# Скопируйте в .env: cp .env.example .env

# local | prod (в prod приложение не стартует с дефолтными SECRET_KEY и POSTGRES_PASSWORD)
ENVIRONMENT=local

# Логи в JSON (true для прода, false — читаемый вывод для разработки)
LOG_JSON=false

# Подпись JWT-токенов; сгенерировать: openssl rand -hex 32
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Часовой пояс компании: в нём считается «сегодня» для отчётов и время напоминаний
COMPANY_TZ=Europe/Moscow

# Когда напоминать о несданном отчёте; ставится в конец окна сдачи, не в начало
REMINDER_TIME=20:00

# PostgreSQL: эти же переменные использует контейнер postgres при инициализации
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=stroytrack
POSTGRES_PASSWORD=stroytrack
POSTGRES_DB=stroytrack